  <bpmn:error id="Error_FraudTransferCanceled" name="TransferCanceledException" errorCode="TRANSFER_CANCELED" />
  <bpmn:process id="fraudCheck" name="Фрод проверка" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_0oaogv4</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0wx3lbr" name="Проверка на частоту переводов" camunda:delegateExpression="${checkTransferFrequencyDelegate}">
      <bpmn:incoming>Flow_0oaogv4</bpmn:incoming>
      <bpmn:outgoing>Flow_1mr9frf</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0oaogv4" sourceRef="StartEvent_1" targetRef="Activity_0wx3lbr" />
    <bpmn:sequenceFlow id="Flow_1mr9frf" sourceRef="Activity_0wx3lbr" targetRef="Gateway_04bse0x" />
    <bpmn:exclusiveGateway id="Gateway_04bse0x" name="Успешно?" default="Flow_1h7ldkq">
      <bpmn:incoming>Flow_1mr9frf</bpmn:incoming>
      <bpmn:outgoing>Flow_0upud1y</bpmn:outgoing>
      <bpmn:outgoing>Flow_1h7ldkq</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0upud1y" name="да" sourceRef="Gateway_04bse0x" targetRef="Event_0jqdmlz">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${fraudCheckPassed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1h7ldkq" name="нет" sourceRef="Gateway_04bse0x" targetRef="Event_10jeuxv" />
    <bpmn:endEvent id="Event_0jqdmlz" name="Success">
      <bpmn:incoming>Flow_0upud1y</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_10jeuxv" name="TransferCanceledException">
      <bpmn:incoming>Flow_1h7ldkq</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_14ejoy2" errorRef="Error_FraudTransferCanceled" />
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="fraudCheck">
