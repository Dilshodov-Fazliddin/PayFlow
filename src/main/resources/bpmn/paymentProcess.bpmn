      <bpmn:outgoing>Flow_1cqfbxb</bpmn:outgoing>
      <bpmn:outgoing>Flow_1nafga2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0gp399p" sourceRef="Activity_0ek0trm" targetRef="Activity_0461vsh" />
    <bpmn:serviceTask id="Activity_06reysv" name="Списание и зачисления на счет" camunda:delegateExpression="${transferMoneyDelegate}">
      <bpmn:incoming>Flow_1cqfbxb</bpmn:incoming>
      <bpmn:outgoing>Flow_03lmq3l</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1cqfbxb" name="да" sourceRef="Gateway_0b7kp2u" targetRef="Activity_06reysv">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${allChecksPassed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0c3hzt6">
      <bpmn:incoming>Flow_03lmq3l</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_03lmq3l" sourceRef="Activity_06reysv" targetRef="Event_0c3hzt6" />
    <bpmn:endEvent id="Event_0g2q130" name="TransferCanceledException">
      <bpmn:incoming>Flow_1izx4ok</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1paagtw" errorRef="Error_TransferCanceled" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1nafga2" name="нет" sourceRef="Gateway_0b7kp2u" targetRef="Activity_0pkunb3" />
    <bpmn:serviceTask id="Activity_0pkunb3" name="Rollback" camunda:delegateExpression="${rollbackDelegate}">
      <bpmn:incoming>Flow_1nafga2</bpmn:incoming>
      <bpmn:outgoing>Flow_1izx4ok</bpmn:outgoing>
