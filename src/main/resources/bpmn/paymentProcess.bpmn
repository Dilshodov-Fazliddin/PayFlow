    <bpmn:sequenceFlow id="Flow_1izx4ok" sourceRef="Activity_0pkunb3" targetRef="Event_0g2q130" />
    <bpmn:callActivity id="Activity_0461vsh" name="Фрод проверка" calledElement="fraudCheckProcess">
