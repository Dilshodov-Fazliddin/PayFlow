  <bpmn:error id="Error_TransferCanceled" name="TransferCanceledException" errorCode="TRANSFER_CANCELED" />
  <bpmn:process id="paymentProcess" name="Валидация баланса пользователя" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1q8rg5s</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_02dwq87" name="Проверка аккаунта в системе" camunda:delegateExpression="${validateAccountsDelegate}">
      <bpmn:incoming>Flow_1q8rg5s</bpmn:incoming>
      <bpmn:outgoing>Flow_0fzlfrm</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1q8rg5s" sourceRef="StartEvent_1" targetRef="Activity_02dwq87" />
    <bpmn:serviceTask id="Activity_05y15qf" name="Валидация баланса счета" camunda:delegateExpression="${validateBalanceDelegate}">
      <bpmn:incoming>Flow_0fzlfrm</bpmn:incoming>
      <bpmn:outgoing>Flow_14ol9qc</bpmn:outgoing>
    </bpmn:serviceTask>
