    <bpmn:serviceTask id="Activity_0ek0trm" name="Проверка суточного лимита пользователя" camunda:delegateExpression="${checkDailyLimitDelegate}">
      <bpmn:incoming>Flow_14ol9qc</bpmn:incoming>
      <bpmn:outgoing>Flow_0gp399p</bpmn:outgoing>
    </bpmn:serviceTask>

